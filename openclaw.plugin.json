{
  "id": "agent-home",
  "name": "Agent Home Display",
  "description": "Zero-click ambient second-screen status display for OpenClaw agents.",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "activation": {
    "onStartup": true,
    "onRoutes": ["agent-home"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "privacyMode": {
        "type": "string",
        "enum": ["ambient"],
        "default": "ambient"
      },
      "refreshMs": {
        "type": "number",
        "default": 10000
      },
      "agentName": {
        "type": "string"
      },
      "workspaceName": {
        "type": "string"
      }
    }
  }
}
